# API
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=   # optional — omit to use api.anthropic.com directly
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
CLAUDE_DIR=/home/YOUR_USER/.claude

# Dev server ports (change if defaults are taken by Docker)
API_PORT=8001
WEBAPP_PORT=5174

# Frontend (Vite exposes only VITE_* to the browser client)
VITE_API_BASE=http://localhost:8001
VITE_PROJECT_SLUG=home-YOUR_USER-Github-YOUR_REPO  # slug = cwd with / replaced by -, strip leading -

# CORS allowed origins (comma-separated). Defaults cover both standard and dev.sh ports.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
